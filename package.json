{
  "name": "oc-auto-updater",
  "version": "0.0.6",
  "description": "OpenCode plugin that automatically updates installed plugins to their latest npm versions",
  "keywords": [
    "opencode",
    "plugin",
    "auto-update"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./server": {
      "import": "./dist/index.mjs"
    },
    "./tui": {
      "import": "./dist/tui.mjs"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abs3ntdev/oc-auto-updater"
  },
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo"
  ],
  "scripts": {
    "build": "pkgroll",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "release": "bun install && bun run build && npm publish"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0",
    "@opentui/core": ">=0.1.96",
    "@opentui/solid": ">=0.1.96"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.10",
    "@opencode-ai/sdk": "^1.3.10",
    "@opentui/core": "^0.1.96",
    "@opentui/solid": "^0.1.96",
    "@types/node": "^24.0.0",
    "pkgroll": "^2.27.0",
    "typescript": "^5.8.0"
  }
}
